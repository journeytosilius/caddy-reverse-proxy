# global options
{
	admin off
	persist_config off
	auto_https off
	log {
		format json
	}
	servers {
		trusted_proxies static private_ranges
	}
}

(lb_settings) {
	lb_policy round_robin
	lb_retries 100
	lb_try_duration 10s
	lb_try_interval 250ms
}

(passive_health_checks) {
	fail_duration 60s
	max_fails 300
	unhealthy_latency 5s
	unhealthy_request_count 200
}

# Reusable frontend upstream block (same as your original)
(frontend_proxy) {
	reverse_proxy {
		dynamic a {
			name {$FRONTEND_DOMAIN}
			port {$FRONTEND_PORT}
			refresh 1s
			dial_timeout 30s
			versions ipv4 ipv6
		}

		import lb_settings
		import passive_health_checks
		header_up Host {upstream_hostport}
	}
}

# site block
:{$PORT} {
	log {
		format json
	}

	# --- 1) BACKEND API (unchanged) ---
	handle_path {$BACKEND_PATH:/api}/* {
		reverse_proxy {
			dynamic a {
				name {$BACKEND_DOMAIN}
				port {$BACKEND_PORT}
				refresh 1s
				dial_timeout 30s
				versions ipv4 ipv6
			}

			import lb_settings
			import passive_health_checks
			header_up Host {upstream_hostport}
		}
	}

	# --- 2) STATIC ASSETS (NO BASIC AUTH) ---
	@assets {
		path /assets/* /favicon.ico /logo.svg /manifest.json /robots.txt
		path_regexp static \.(js|css|map|png|jpg|jpeg|gif|svg|webp|ico)$
	}
	handle @assets {
		import frontend_proxy
	}

	# --- 3) SPA ROUTES (BASIC AUTH ONLY HERE) ---
	handle {
		basicauth {
			{$BASIC_AUTH_USER} {$BASIC_AUTH_PASS}
		}

		import frontend_proxy
	}
}
