:{$PORT} {
    log {
        format json
    }

    # -------------------------------------------------------------
    # 1. API REQUESTS (The Exception)
    # -------------------------------------------------------------
    # If the URL starts with /api, we Proxy it immediately.
    # WE DO NOT ADD BASIC AUTH HERE.
    # This fixes the "401" errors on your backend calls.
    handle_path {$BACKEND_PATH:/api}/* {
        reverse_proxy {
            dynamic a {
                name {$BACKEND_DOMAIN}
                port {$BACKEND_PORT}
                refresh 1s
                dial_timeout 30s
                versions ipv4 ipv6
            }
            import lb_settings
            import passive_health_checks
            header_up Host {upstream_hostport}
        }
    }

    # -------------------------------------------------------------
    # 2. EVERYTHING ELSE (The Protected Frontend)
    # -------------------------------------------------------------
    # If the URL did NOT match /api above, it falls into this bucket.
    # This includes /, /index.html, /logo.svg, /assets/index.js.
    # WE FORCE PASSWORD HERE.
    handle {
        basicauth {
            # Remember: This must be the HASH, not the plaintext
            {$BASIC_AUTH_USER} {$BASIC_AUTH_PASS}
        }

        reverse_proxy {
            dynamic a {
                name {$FRONTEND_DOMAIN}
                port {$FRONTEND_PORT}
                refresh 1s
                dial_timeout 30s
                versions ipv4 ipv6
            }
            import lb_settings
            import passive_health_checks
            header_up Host {upstream_hostport}
        }
    }
}